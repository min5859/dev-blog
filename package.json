{
  "name": "dev-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "check": "npm run collect:linux && npm run draft:linux && npm run rewrite:linux && npm run build",
    "collect:linux": "node scripts/collect-linux.mjs",
    "daily:linux": "node scripts/run-daily-linux.mjs",
    "daily:linux:publish": "PUBLISH_DAILY=1 node scripts/run-daily-linux.mjs",
    "draft:linux": "node scripts/draft-linux.mjs",
    "publish:linux": "node scripts/publish-linux.mjs",
    "rewrite:linux": "node scripts/ai-rewrite-linux.mjs",
    "rewrite:linux:claude": "AI_ADAPTER=claude node scripts/ai-rewrite-linux.mjs",
    "weekly:linux": "node scripts/weekly-linux.mjs",
    "weekly:linux:claude": "AI_ADAPTER=claude node scripts/weekly-linux.mjs",
    "collect:android": "node scripts/collect-android.mjs",
    "draft:android": "node scripts/draft-android.mjs",
    "rewrite:android": "node scripts/ai-rewrite-android.mjs",
    "rewrite:android:claude": "AI_ADAPTER=claude node scripts/ai-rewrite-android.mjs",
    "publish:android": "node scripts/publish-android.mjs",
    "daily:android": "node scripts/run-daily-android.mjs",
    "daily:android:publish": "PUBLISH_DAILY=1 node scripts/run-daily-android.mjs",
    "test": "node --test scripts/*.test.mjs",
    "dev": "npm run build && node scripts/serve-site.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
