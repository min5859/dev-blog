{
  "name": "dev-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "check": "npm run collect:linux && npm run draft:linux && npm run rewrite:linux && npm run build",
    "collect:linux": "node scripts/collect-linux.mjs",
    "draft:linux": "node scripts/draft-linux.mjs",
    "rewrite:linux": "node scripts/ai-rewrite-linux.mjs",
    "rewrite:linux:claude": "AI_ADAPTER=claude node scripts/ai-rewrite-linux.mjs",
    "dev": "npm run build && node scripts/serve-site.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
